{
  "name": "cellarbridge-operations-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "generate:api": "openapi-typescript ../contracts/openapi/cellarbridge-api.yaml -o src/api/generated/schema.d.ts",
    "check:generated": "pnpm generate:api && git diff --exit-code -- src/api/generated/schema.d.ts",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -b && vite build",
    "test:e2e": "playwright test",
    "test:e2e:identity": "playwright test --config playwright.live.config.ts",
    "test:e2e:partner": "playwright test --config playwright.partner.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@tanstack/react-query": "5.101.2",
    "antd": "6.5.1",
    "oidc-client-ts": "3.5.0",
    "openapi-fetch": "0.17.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "7.81.0",
    "react-oidc-context": "3.3.1",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  }
}
