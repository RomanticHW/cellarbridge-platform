{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "vite.config.ts",
    "playwright.config.ts",
    "playwright.live.config.ts",
    "playwright.partner.config.ts",
    "playwright.catalog.config.ts",
    "playwright.quotation.config.ts",
    "playwright.acceptance.config.ts",
    "playwright.order.config.ts",
    "playwright.fulfillment.config.ts",
    "playwright.exception.config.ts",
    "eslint.config.js",
    "e2e/**/*.ts"
  ]
}
