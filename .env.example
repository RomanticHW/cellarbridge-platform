# Local-only defaults for the core development profile. Change these outside source control.
POSTGRES_PORT=5432
POSTGRES_DB=cellarbridge
POSTGRES_USER=cellarbridge
POSTGRES_PASSWORD=cellarbridge_local

KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN_USERNAME=local-admin
KEYCLOAK_ADMIN_PASSWORD=local-admin-change-me
OIDC_HOSTNAME=http://localhost:8081
OIDC_AUTHORITY=http://localhost:8081/realms/cellarbridge
OIDC_CLIENT_ID=cellarbridge-console
OIDC_AUDIENCE=cellarbridge-api

BACKEND_PORT=8080
FRONTEND_PORT=5173
CELLARBRIDGE_COMMIT=local
