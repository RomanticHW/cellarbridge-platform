# Local-only defaults for the core development profile. Change these outside source control.
POSTGRES_PORT=5432
POSTGRES_DB=cellarbridge
POSTGRES_USER=cellarbridge
POSTGRES_PASSWORD=cellarbridge_local

KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN_USERNAME=local-admin
KEYCLOAK_ADMIN_PASSWORD=local-admin-change-me
OIDC_HOSTNAME=http://localhost:8081
OIDC_AUTHORITY=http://localhost:8081/realms/cellarbridge
OIDC_CLIENT_ID=cellarbridge-console
OIDC_AUDIENCE=cellarbridge-api

BACKEND_PORT=8080
FRONTEND_PORT=5173
CELLARBRIDGE_COMMIT=local
CELLARBRIDGE_DB_POOL_SIZE=10
CELLARBRIDGE_MCP_ENABLED=true
CELLARBRIDGE_MCP_RESOURCE=https://mcp.cellarbridge.example/mcp
CELLARBRIDGE_MCP_AUDIENCE=https://mcp.cellarbridge.example/mcp
CELLARBRIDGE_MCP_SCOPE=mcp:read
CELLARBRIDGE_MCP_ALLOWED_CLIENTS=cellarbridge-mcp-host
CELLARBRIDGE_MCP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CELLARBRIDGE_MCP_ALLOWED_HOSTS=localhost:8080,127.0.0.1:8080
CELLARBRIDGE_MCP_REST_CONNECTION_RESERVE=2
CELLARBRIDGE_MCP_MAX_REQUEST_BYTES=65536
CELLARBRIDGE_MCP_RATE_CAPACITY=30
CELLARBRIDGE_MCP_RATE_REFILL_PER_SECOND=10
CELLARBRIDGE_MCP_MAX_CONCURRENCY=8
CELLARBRIDGE_MCP_MAX_CLIENT_CONCURRENCY=4
CELLARBRIDGE_MCP_REQUEST_TIMEOUT=PT5S
CELLARBRIDGE_MCP_STATEMENT_TIMEOUT=PT3S
CELLARBRIDGE_MCP_MAX_RESPONSE_BYTES=262144
CELLARBRIDGE_MCP_MAX_COLLECTION_ITEMS=1000
CELLARBRIDGE_MCP_MAX_PAGE_SIZE=100
CELLARBRIDGE_CATALOG_CURSOR_TTL=PT15M
CELLARBRIDGE_AUDIT_CURSOR_TTL=PT15M

# Copy this file to .env and replace these placeholders before starting the full profile.
GRAFANA_ADMIN_USER=local-observer
GRAFANA_ADMIN_PASSWORD=replace-before-full-profile
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
TEMPO_PORT=3200
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
TRACE_SAMPLE_PROBABILITY=1.0
