{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cellarbridge.dev/schemas/events/receivable-created-v1.schema.json",
  "title": "ReceivableCreatedV1",
  "allOf": [
    {
      "$ref": "event-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "cellarbridge.settlement.receivable-created.v1"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "receivableId",
            "receivableNumber",
            "orderId",
            "orderNumber",
            "originalAmount",
            "currency",
            "dueDate",
            "createdAt",
            "triggerType",
            "triggerId"
          ],
          "properties": {
            "receivableId": {
              "type": "string",
              "format": "uuid"
            },
            "receivableNumber": {
              "type": "string"
            },
            "orderId": {
              "type": "string",
              "format": "uuid"
            },
            "orderNumber": {
              "type": "string"
            },
            "originalAmount": {
              "type": "string"
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            "dueDate": {
              "type": "string",
              "format": "date"
            },
            "createdAt": {
              "type": "string",
              "format": "date-time"
            },
            "triggerType": {
              "type": "string"
            },
            "triggerId": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      }
    }
  ]
}
