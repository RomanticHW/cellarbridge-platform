{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cellarbridge.dev/schemas/events/quotation-accepted-v1.schema.json",
  "title": "QuotationAcceptedV1",
  "allOf": [
    {
      "$ref": "event-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "cellarbridge.quotation.accepted.v1"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "quotationId",
            "revisionId",
            "quotationNumber",
            "revision",
            "acceptanceId",
            "acceptedAt",
            "customer",
            "currency",
            "totalAmount",
            "paymentTermDays",
            "route",
            "acceptedTermsVersion",
            "requestedDeliveryDate",
            "deliveryAddress",
            "snapshotHash",
            "lines"
          ],
          "properties": {
            "quotationId": {
              "type": "string",
              "format": "uuid"
            },
            "revisionId": {
              "type": "string",
              "format": "uuid"
            },
            "quotationNumber": {
              "type": "string",
              "minLength": 1,
              "maxLength": 30,
              "pattern": "\\S"
            },
            "revision": {
              "type": "integer",
              "minimum": 1,
              "maximum": 2147483647
            },
            "sourceOwnerId": {
              "type": "string",
              "format": "uuid"
            },
            "acceptanceId": {
              "type": "string",
              "format": "uuid"
            },
            "acceptedAt": {
              "type": "string",
              "format": "date-time"
            },
            "customer": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "partnerId",
                "partnerNumber",
                "displayName",
                "sourceVersion"
              ],
              "properties": {
                "partnerId": {
                  "type": "string",
                  "format": "uuid"
                },
                "partnerNumber": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 80,
                  "pattern": "\\S"
                },
                "displayName": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 160,
                  "pattern": "\\S"
                },
                "sourceVersion": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 2147483647
                }
              }
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            "totalAmount": {
              "type": "string",
              "pattern": "^0*(?:0|[1-9][0-9]{0,14})(?:\\.[0-9]{1,4})?$"
            },
            "paymentTermDays": {
              "type": "integer",
              "minimum": 0,
              "maximum": 180
            },
            "route": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "code",
                "policyVersion",
                "estimatedDeliveryDate"
              ],
              "properties": {
                "code": {
                  "type": "string",
                  "enum": [
                    "SH_GENERAL_TRADE",
                    "NB_BONDED_B2B",
                    "HK_FREE_TRADE"
                  ]
                },
                "policyVersion": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 80,
                  "pattern": "\\S"
                },
                "estimatedDeliveryDate": {
                  "type": "string",
                  "format": "date"
                }
              }
            },
            "acceptedTermsVersion": {
              "type": "string",
              "minLength": 1,
              "maxLength": 50,
              "pattern": "\\S"
            },
            "requestedDeliveryDate": {
              "type": "string",
              "format": "date"
            },
            "deliveryAddress": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "countryCode",
                "province",
                "city",
                "line1"
              ],
              "properties": {
                "countryCode": {
                  "type": "string",
                  "pattern": "^[A-Z]{2}$"
                },
                "province": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 100,
                  "pattern": "\\S"
                },
                "city": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 100,
                  "pattern": "\\S"
                },
                "district": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "minLength": 1,
                  "maxLength": 100,
                  "pattern": "\\S"
                },
                "line1": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 200,
                  "pattern": "\\S"
                },
                "postalCode": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "minLength": 1,
                  "maxLength": 20,
                  "pattern": "\\S"
                }
              }
            },
            "snapshotHash": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "lines": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "quotationLineId",
                  "skuId",
                  "skuCode",
                  "description",
                  "quantity",
                  "unit",
                  "netUnitPrice",
                  "lineTotal",
                  "supplyType"
                ],
                "properties": {
                  "quotationLineId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "skuId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "skuCode": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80,
                    "pattern": "\\S"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 240,
                    "pattern": "\\S"
                  },
                  "quantity": {
                    "type": "string",
                    "pattern": "^(?=.*[1-9])0*(?:0|[1-9][0-9]{0,12})(?:\\.[0-9]{1,6})?$"
                  },
                  "unit": {
                    "type": "string",
                    "enum": [
                      "CASE",
                      "BOTTLE"
                    ]
                  },
                  "netUnitPrice": {
                    "type": "string",
                    "pattern": "^0*(?:0|[1-9][0-9]{0,14})(?:\\.[0-9]{1,4})?$"
                  },
                  "lineTotal": {
                    "type": "string",
                    "pattern": "^0*(?:0|[1-9][0-9]{0,14})(?:\\.[0-9]{1,4})?$"
                  },
                  "supplyPoolId": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "format": "uuid"
                  },
                  "supplyType": {
                    "type": "string",
                    "enum": [
                      "DOMESTIC_ON_HAND",
                      "BONDED_ON_HAND",
                      "HONG_KONG_ON_HAND",
                      "IN_TRANSIT_PRESALE",
                      "OVERSEAS_SOURCING"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
