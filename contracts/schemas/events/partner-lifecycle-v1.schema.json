{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cellarbridge.dev/schemas/events/partner-lifecycle-v1.schema.json",
  "title": "PartnerLifecycleV1",
  "allOf": [
    { "$ref": "event-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "type": {
          "enum": [
            "cellarbridge.partner.submitted-for-review.v1",
            "cellarbridge.partner.activated.v1",
            "cellarbridge.partner.changes-requested.v1",
            "cellarbridge.partner.rejected.v1",
            "cellarbridge.partner.suspended.v1"
          ]
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["partnerId", "number"],
          "properties": {
            "partnerId": { "type": "string", "format": "uuid" },
            "number": { "type": "string", "minLength": 1 },
            "submittedBy": { "type": "string", "format": "uuid" },
            "eligibilityVersion": { "type": "integer", "minimum": 1 },
            "safeReason": { "type": "string", "maxLength": 500 }
          }
        }
      }
    }
  ]
}
