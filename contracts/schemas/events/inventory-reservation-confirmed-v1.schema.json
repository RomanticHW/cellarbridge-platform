{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cellarbridge.dev/schemas/events/inventory-reservation-confirmed-v1.schema.json",
  "title": "InventoryReservationConfirmedV1",
  "allOf": [
    {
      "$ref": "event-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "cellarbridge.inventory.reservation-confirmed.v1"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reservationId",
            "reservationNumber",
            "orderId",
            "orderNumber",
            "confirmedAt",
            "allocations"
          ],
          "properties": {
            "reservationId": {
              "type": "string",
              "format": "uuid"
            },
            "reservationNumber": {
              "type": "string"
            },
            "orderId": {
              "type": "string",
              "format": "uuid"
            },
            "orderNumber": {
              "type": "string"
            },
            "requestHash": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "supplyDecisionHash": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "routeCode": {
              "type": "string",
              "enum": ["SH_GENERAL_TRADE", "NB_BONDED_B2B", "HK_FREE_TRADE"],
              "description": "Selected route for downstream plan selection. Optional for backward-compatible V1 reads; current producers always include it."
            },
            "confirmedAt": {
              "type": "string",
              "format": "date-time"
            },
            "allocations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "orderLineId",
                  "lotId",
                  "lotCode",
                  "quantity",
                  "unit"
                ],
                "properties": {
                  "orderLineId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "skuId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "supplyPoolId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "lotId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "lotCode": {
                    "type": "string"
                  },
                  "supplyType": {
                    "type": "string",
                    "enum": [
                      "DOMESTIC_ON_HAND",
                      "BONDED_ON_HAND",
                      "HONG_KONG_ON_HAND"
                    ]
                  },
                  "quantity": {
                    "type": "string"
                  },
                  "unit": {
                    "type": "string",
                    "enum": [
                      "CASE",
                      "BOTTLE"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
