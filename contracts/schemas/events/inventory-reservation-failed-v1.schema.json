{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cellarbridge.dev/schemas/events/inventory-reservation-failed-v1.schema.json",
  "title": "InventoryReservationFailedV1",
  "allOf": [
    {
      "$ref": "event-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "cellarbridge.inventory.reservation-failed.v1"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reservationId",
            "reservationNumber",
            "orderId",
            "orderNumber",
            "failedAt",
            "reasonCode",
            "shortages"
          ],
          "properties": {
            "reservationId": {
              "type": "string",
              "format": "uuid"
            },
            "reservationNumber": {
              "type": "string"
            },
            "orderId": {
              "type": "string",
              "format": "uuid"
            },
            "orderNumber": {
              "type": "string"
            },
            "requestHash": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "supplyDecisionHash": {
              "type": ["string", "null"],
              "pattern": "^[0-9a-f]{64}$"
            },
            "failedAt": {
              "type": "string",
              "format": "date-time"
            },
            "reasonCode": {
              "type": "string",
              "enum": [
                "INVENTORY_INSUFFICIENT",
                "SUPPLY_NOT_AUTOMATICALLY_RESERVABLE",
                "ALLOCATION_CONFLICT",
                "INTERNAL_FAILURE",
                "INVENTORY_FIXED_POOL_INELIGIBLE",
                "INVENTORY_ALLOCATION_CONFLICT",
                "SUPPLY_DECISION_MISSING",
                "RESERVATION_REQUEST_CONFLICT"
              ]
            },
            "shortages": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "orderLineId",
                  "skuId",
                  "skuCode",
                  "requestedQuantity",
                  "observedAvailableQuantity",
                  "shortageQuantity",
                  "unit"
                ],
                "properties": {
                  "orderLineId": { "type": "string", "format": "uuid" },
                  "skuId": { "type": "string", "format": "uuid" },
                  "skuCode": { "type": "string" },
                  "requestedQuantity": { "type": "string" },
                  "observedAvailableQuantity": { "type": "string" },
                  "shortageQuantity": { "type": "string" },
                  "unit": { "type": "string", "enum": ["CASE", "BOTTLE"] }
                }
              }
            },
            "lineFailures": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "orderLineId",
                  "skuId",
                  "skuCode",
                  "requestedQuantity",
                  "unit",
                  "allocationMode",
                  "supplyPoolId",
                  "supplyType",
                  "observedAvailableQuantity",
                  "shortageQuantity"
                ],
                "properties": {
                  "orderLineId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "skuId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "skuCode": {
                    "type": "string"
                  },
                  "requestedQuantity": {
                    "type": "string"
                  },
                  "allocationMode": {
                    "type": ["string", "null"],
                    "enum": ["ROUTE_ELIGIBLE_AUTO", "FIXED_POOL", null]
                  },
                  "supplyPoolId": {
                    "type": ["string", "null"],
                    "format": "uuid"
                  },
                  "supplyType": {
                    "type": ["string", "null"],
                    "enum": [
                      "DOMESTIC_ON_HAND",
                      "BONDED_ON_HAND",
                      "HONG_KONG_ON_HAND",
                      "IN_TRANSIT_PRESALE",
                      "OVERSEAS_SOURCING",
                      null
                    ]
                  },
                  "observedAvailableQuantity": {
                    "type": ["string", "null"]
                  },
                  "shortageQuantity": {
                    "type": ["string", "null"]
                  },
                  "unit": {
                    "type": "string",
                    "enum": [
                      "CASE",
                      "BOTTLE"
                    ]
                  }
                }
              }
            },
            "retryable": {
              "type": "boolean"
            }
          }
        }
      }
    }
  ]
}
